{
  "expo": {
    "name": "DifferentiationBee",
    "slug": "DifferentiationBee",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "differentiationbee",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.differentiationbee",
      "allowBackup": false,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static"
    },
    "plugins": ["expo-router", "expo-localization"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
